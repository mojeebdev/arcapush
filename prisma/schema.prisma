generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum StartupTier {
  FREE
  PINNED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id            String   @id @default(cuid())

  walletAddress String?  @unique
  email         String?  @unique
  name          String?
  role          String   @default("viewer") // viewer | founder | admin
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  startups       Startup[]
  accessRequests AccessRequest[]
}

model Startup {
  id                String   @id @default(cuid())


  slug              String?  @unique           // SEO-friendly URL: /startup/lovable
  metaTitle         String?                    // Custom <title> tag (falls back to name)
  metaDescription   String?  @db.Text          // Custom <meta name="description"> (falls back to tagline)
  canonicalUrl      String?                    // Override canonical if needed (rare)

  
  name              String
  tagline           String
  problemStatement  String   @db.Text
  bannerUrl         String
  logoUrl           String?
  category          String   @default("DeFi")
  website           String?
  twitter           String?


  founderName       String
  founderEmail      String
  founderLinkedIn   String?
  founderTwitter    String?
  pitchDeckUrl      String?

  
  approved          Boolean     @default(false)


  tier              StartupTier @default(FREE)
  pinnedAt          DateTime?
  pinnedUntil       DateTime?
  pinTxHash         String?
  pinChain          String?     // "base" | "solana"

  
  founderId         String?
  founder           User?        @relation(fields: [founderId], references: [id])
  accessRequests    AccessRequest[]
  reviews           Review[]                    // ← NEW

  
  viewCount         Int          @default(0)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt


  @@index([tier, pinnedUntil])
  @@index([createdAt])
  @@index([approved, createdAt])
  @@index([slug])
  @@index([category, approved])
}

model AccessRequest {
  id                String        @id @default(cuid())

  // Requester info
  requesterName      String
  requesterEmail     String
  requesterFirm      String
  requesterRole      String?
  requesterLinkedIn  String?

  // Status
  status             RequestStatus @default(PENDING)

  // Relations
  startupId          String
  startup            Startup       @relation(fields: [startupId], references: [id], onDelete: Cascade)
  requesterId        String?
  requester          User?         @relation(fields: [requesterId], references: [id])

  // Timestamps
  createdAt          DateTime      @default(now())
  reviewedAt         DateTime?

  @@unique([requesterEmail, startupId])
  @@index([startupId, status])
}

model Payment {
  id          String    @id @default(cuid())
  startupId   String
  chain       String    // "base" | "solana"
  txHash      String    @unique
  amount      String
  currency    String    // "USDC" | "SOL"
  walletFrom  String
  walletTo    String
  confirmedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([startupId])
}


model Review {
  id          String   @id @default(cuid())

  // Who left it
  name        String                  // shown publicly
  email       String                  // stored only, never shown publicly

  // The review
  rating      Int                     // 1 to 5
  comment     String   @db.Text

  // Which startup
  startupId   String
  startup     Startup  @relation(fields: [startupId], references: [id], onDelete: Cascade)

  // Timestamps
  createdAt   DateTime @default(now())

  // One review per email per startup
  @@unique([email, startupId])
  @@index([startupId])
}
